# name: test/sql/coda_offline.test
# description: Offline sanity checks for the Coda extension
# group: [sql]

require coda

statement ok
LOAD coda;

statement error
ATTACH 'dummy-doc' AS coda_missing_token (TYPE coda);
----
Invalid Input Error: failed to resolve Coda attach config: missing credential

statement ok
CREATE SECRET coda_offline (TYPE coda);

statement error
CREATE SECRET coda_missing_token_env (TYPE coda, TOKEN_ENV 'DUCKDB_CODA_ENV_DOES_NOT_EXIST');
----
Invalid Input Error: failed to resolve Coda token environment variable: failed to read environment variable DUCKDB_CODA_ENV_DOES_NOT_EXIST: environment variable not found

statement error
ATTACH 'dummy-doc' AS coda_missing_token_env (TYPE coda, TOKEN_ENV 'DUCKDB_CODA_ENV_DOES_NOT_EXIST');
----
Invalid Input Error: failed to resolve Coda attach config: failed to read environment variable DUCKDB_CODA_ENV_DOES_NOT_EXIST: environment variable not found

statement error
ATTACH 'dummy-doc' AS coda_bad_metadata_option (TYPE coda, TOKEN 'dummy-token', INCLUDE_ROW_METADATA 'maybe');
----
Invalid Input Error: failed to resolve Coda attach config: invalid boolean attach option
